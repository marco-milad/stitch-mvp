# =============================================================================
# Stitch MVP — Master Environment Template
# =============================================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` (it is gitignored).
# Each app (apps/api, apps/admin, apps/mobile) has its own .env.example with
# only the vars relevant to it; this file is the master reference.
# =============================================================================

# -----------------------------------------------------------------------------
# App / runtime
# -----------------------------------------------------------------------------
APP_ENV=development
APP_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# API (apps/api)
# -----------------------------------------------------------------------------
APP_PORT=8000

# Supabase Postgres (use the *pooled* connection string, port 6543)
# Get from: Supabase Dashboard → Project Settings → Database → Connection String
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Upstash Redis (REST URL + token format works with `redis-py` via the upstash client,
# or use the `rediss://` URL if you prefer the standard redis client)
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# Clerk
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWKS_URL=https://<your-frontend-api>.clerk.accounts.dev/.well-known/jwks.json

# Google Gemini Live (AI voice)
GEMINI_API_KEY=xxx
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Supabase (for storage SDK)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_KEY=xxx

# CORS — comma-separated origins
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8081

# -----------------------------------------------------------------------------
# Admin (apps/admin) — Next.js
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/

# -----------------------------------------------------------------------------
# Mobile (apps/mobile) — Expo
# (vars MUST be prefixed EXPO_PUBLIC_ to be exposed to the client)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# -----------------------------------------------------------------------------
# Pusher (account only — Week 1, no implementation yet)
# -----------------------------------------------------------------------------
PUSHER_APP_ID=xxx
PUSHER_KEY=xxx
PUSHER_SECRET=xxx
PUSHER_CLUSTER=eu

# -----------------------------------------------------------------------------
# Sentry (account only — Week 1, no implementation yet)
# -----------------------------------------------------------------------------
SENTRY_DSN=
