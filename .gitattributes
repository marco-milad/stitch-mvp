# Default: normalize text files to LF in the repo, OS-native in working dir
* text=auto eol=lf

# Source code — explicit LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.py text eol=lf

# Husky hooks and shell scripts MUST be LF (Git Bash will fail on CRLF)
.husky/* text eol=lf
*.sh text eol=lf

# Windows-only scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Lockfiles — preserve as-is, mark as generated for diffs
pnpm-lock.yaml -diff linguist-generated=true
package-lock.json -diff linguist-generated=true
yarn.lock -diff linguist-generated=true

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.mp4 binary
*.mov binary
