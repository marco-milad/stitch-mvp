# =============================================================================
# Stitch API — Environment Template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# Runtime
APP_ENV=development
APP_PORT=8000
APP_LOG_LEVEL=INFO

# Database (Supabase Postgres)
# Direct connection (port 5432) is used here; switch to the pooled URL
# (postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres) for prod runtime.
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# Redis (Upstash)
# Grab the rediss:// URL from Upstash dashboard → Connect → "redis-py" tab
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# Clerk
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWKS_URL=https://<your-frontend-api>.clerk.accounts.dev/.well-known/jwks.json

# Google Gemini Live (AI voice)
GEMINI_API_KEY=xxx
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_VOICE_NAME=Aoede
GEMINI_LANGUAGE=ar-EG

# Supabase (for storage SDK)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_KEY=xxx

# CORS — comma-separated origins
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8081
