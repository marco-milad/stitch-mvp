# =============================================================================
# Stitch API — Environment Template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# Runtime
APP_ENV=development
APP_PORT=8000
APP_LOG_LEVEL=INFO

# Database (Supabase Postgres) — use the *pooler* URL.
# Supabase's direct host `db.<ref>.supabase.co` is IPv6-only since late 2024 and is
# unreachable from many local networks. Use the pooler in both modes:
#   - Session mode (port 5432) — for migrations, prepared statements, advisory locks
#   - Transaction mode (port 6543) — for app runtime (better connection limits)
# Username is `postgres.<project-ref>` (note the dot) for both pooler modes.
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Redis (Upstash)
# Grab the rediss:// URL from Upstash dashboard → Connect → "redis-py" tab
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# Clerk
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWKS_URL=https://<your-frontend-api>.clerk.accounts.dev/.well-known/jwks.json
# Webhook signing secret from Clerk Dashboard → Webhooks → Endpoints.
# Required in production. In local dev leave it unset to disable
# signature verification (the route accepts all bodies — useful when
# replaying a fixture through curl). NEVER skip verification in
# anything user-facing.
CLERK_WEBHOOK_SECRET=whsec_xxx

# Google Gemini Live (AI voice)
GEMINI_API_KEY=xxx
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_VOICE_NAME=Aoede
GEMINI_LANGUAGE=ar-EG

# Supabase (for storage SDK)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_KEY=xxx

# CORS — comma-separated origins
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8081
