# =============================================================================
# Stitch Mobile (Expo) — env template
# Vars MUST be prefixed EXPO_PUBLIC_ to be exposed to the client bundle.
# Copy to `.env` (gitignored) and fill in real values.
# =============================================================================

# API base — when running on a physical device via Expo Go, replace `localhost`
# with your laptop's LAN IP (e.g. http://192.168.1.42:8000). The phone can't
# reach localhost on your dev machine.
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_API_WS_URL=ws://localhost:8000

# Clerk (mobile uses the same publishable key as admin)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
